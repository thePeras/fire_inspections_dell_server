{
    "name": "dell-server",
    "version": "1.0.0",
    "scripts": {
        "start": "node dist/index.js",
        "dev": "ts-node index.ts",
        "build": "tsc",
        "tunnel": "export $(cat .env | xargs) && cloudflared tunnel run",
        "server:prod": "concurrently \"npm start\" \"npm run tunnel\"",
        "server:dev": "concurrently \"npm run dev\" \"npm run tunnel\""
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.39.0",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "winston": "^3.19.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.4",
        "concurrently": "^9.2.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3"
    }
}